---
const steps = [
  { n: '01', title: 'Preview', body: "Tell us your business name. Within 48 hours you'll see a homepage designed for you — free, no strings." },
  { n: '02', title: 'Launch', body: 'Like it? We build the full site and switch on the systems you choose. Most launches take 2–3 weeks.' },
  { n: '03', title: 'Grow', body: "Reviews, rankings, bookings, and posts run week after week. You'll see every call and lead in your dashboard." },
];
---
<ol class="steps">
  {steps.map((s) => (
    <li class="step">
      <span class="step__n">{s.n}</span>
      <h3 class="step__title">{s.title}</h3>
      <p class="step__body">{s.body}</p>
    </li>
  ))}
</ol>

<style>
  .steps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  .step { border-top: 2px solid var(--coral); padding-top: 1.25rem; }
  .step__n { font-size: 0.85rem; letter-spacing: 0.16em; font-weight: 600; color: var(--coral); }
  .step__title { margin: 0.6rem 0 0.7rem; font-size: 1.75rem; font-weight: 500; color: var(--ivory); }
  .step__body { color: var(--ivory); opacity: 0.85; margin: 0; }
  @media (min-width: 760px) { .steps { grid-template-columns: repeat(3, 1fr); gap: 2rem; } }
</style>
