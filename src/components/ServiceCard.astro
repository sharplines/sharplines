---
interface Props { title: string; blurb: string; href: string; }
const { title, blurb, href } = Astro.props;
---
<a href={href} class="scard">
  <h3 class="scard__title">{title}</h3>
  <p class="scard__blurb">{blurb}</p>
  <span class="scard__more">Learn more →</span>
</a>

<style>
  .scard {
    display: flex; flex-direction: column;
    padding: 1.75rem;
    border: 1px solid var(--hairline); border-radius: var(--radius);
    background: var(--paper); color: var(--ink);
    box-shadow: inset 0 0 0 0 var(--chalk);
    transition: box-shadow 0.18s ease, transform 0.18s ease;
    height: 100%;
  }
  .scard:hover { box-shadow: inset 4px 0 0 0 var(--chalk); transform: translateY(-2px); }
  .scard__title { margin-bottom: 0.6rem; }
  .scard__blurb { color: var(--steel); font-size: 1rem; margin: 0; flex: 1; }
  .scard__more { margin-top: 1.25rem; font-family: var(--font-mono); font-size: 0.8125rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--chalk); }
</style>
