---
interface Props { title: string; blurb: string; href: string; }
const { title, blurb, href } = Astro.props;
---
<a href={href} class="scard">
  <h3 class="scard__title">{title}</h3>
  <p class="scard__blurb">{blurb}</p>
  <span class="scard__more">Learn more →</span>
</a>

<style>
  .scard {
    display: flex; flex-direction: column; height: 100%;
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--ivory); color: var(--green);
    border: 1px solid rgba(14,47,40,0.12); border-radius: var(--radius);
    box-shadow: inset 0 0 0 0 var(--coral);
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }
  .scard:hover { box-shadow: inset 5px 0 0 0 var(--coral); transform: translateY(-3px); }
  .scard__title { font-size: 1.4rem; font-weight: 500; margin-bottom: 0.7rem; }
  .scard__blurb { color: var(--ink); opacity: 0.8; font-size: 1rem; margin: 0; flex: 1; }
  .scard__more { margin-top: 1.5rem; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--coral); font-weight: 600; }
</style>
