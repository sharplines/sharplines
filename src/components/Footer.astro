---
import { trades } from '../data/trades';
const services = [
  { label: 'Websites that sell', href: '/services#websites' },
  { label: 'Get found on Google', href: '/services#seo' },
  { label: 'Reviews on autopilot', href: '/services#reviews' },
  { label: 'Online booking', href: '/services#booking' },
  { label: 'Never miss a call', href: '/services#phone' },
  { label: 'Social on autopilot', href: '/services#social' },
  { label: 'Ads that pay for themselves', href: '/services#ads' },
];
---

<footer class="footer theme-ink">
  <div class="container footer__grid">
    <div class="footer__brand">
      <a href="/" class="wordmark">Sharplines</a>
      <p>More booked jobs for local GTA businesses.</p>
    </div>

    <nav class="footer__col" aria-label="Services">
      <p class="footer__head">Services</p>
      {services.map((s) => <a href={s.href} class="footer__link">{s.label}</a>)}
    </nav>

    <nav class="footer__col" aria-label="Who we help">
      <p class="footer__head">Who we help</p>
      {trades.map((t) => <a href={`/for/${t.slug}`} class="footer__link">{t.label}</a>)}
    </nav>

    <div class="footer__col">
      <p class="footer__head">Contact</p>
      <a href="tel:+15145602266" class="footer__link">(514) 560-2266</a>
      <a href="mailto:hi@sharplines.ca" class="footer__link">hi@sharplines.ca</a>
      <p class="footer__meta">Toronto &amp; GTA</p>
      <a href="/privacy" class="footer__link footer__privacy">Privacy</a>
    </div>
  </div>

  <div class="container footer__base"><span>© 2026 Sharplines Studio</span></div>
</footer>

<style>
  .footer { padding-top: clamp(3.5rem, 7vw, 5rem); padding-bottom: 2rem; }
  .footer__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.25rem; }
  .wordmark { color: var(--ivory); font-weight: 600; font-size: 1.5rem; letter-spacing: -0.02em; }
  .footer__brand { grid-column: 1 / -1; }
  .footer__brand p { color: var(--mint); opacity: 0.55; margin-top: 0.85rem; max-width: 26ch; }
  .footer__col { display: flex; flex-direction: column; }
  .footer__head { font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mint); opacity: 0.45; margin: 0 0 1rem; }
  .footer__link { color: var(--mint); font-size: 0.95rem; padding: 0.35rem 0; opacity: 0.85; }
  .footer__link:hover { opacity: 1; color: #fff; text-decoration: underline; text-decoration-color: var(--coral); text-underline-offset: 3px; }
  .footer__meta { color: var(--mint); opacity: 0.5; font-size: 0.85rem; letter-spacing: 0.04em; margin: 0.5rem 0; }
  .footer__privacy { margin-top: 0.25rem; }
  .footer__base { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.12); font-size: 0.82rem; letter-spacing: 0.04em; color: var(--mint); opacity: 0.5; }

  @media (min-width: 760px) { .footer__grid { grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 2.5rem; } .footer__brand { grid-column: auto; } }
</style>
