---
const year = new Date().getFullYear();
---

<footer class="site-footer theme-ink">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="wordmark">
        <svg class="mark" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
          <path d="M3 21 L21 3 M8 21 L21 8 M14 21 L21 14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
        </svg>
        <span>SharpLines<sup>™</sup></span>
      </a>
      <p class="footer-tag">Sharp design for businesses that run on reputation.</p>
    </div>

    <div class="footer-col">
      <span class="footer-label">Contact</span>
      <a href="mailto:hello@sharplines.studio" class="link-underline">hello@sharplines.studio</a>
    </div>

    <div class="footer-col">
      <span class="footer-label">Legal</span>
      <a href="#" class="link-underline">Terms &amp; Conditions</a>
      <a href="#" class="link-underline">Privacy Policy</a>
    </div>
  </div>

  <div class="container footer-base">
    <span>© {year} SharpLines. All rights reserved.</span>
    <a href="mailto:hello@sharplines.studio" class="link-underline">hello@sharplines.studio</a>
  </div>
</footer>

<style>
  .site-footer { padding-block: clamp(3.5rem, 8vw, 6rem) 2.5rem; }
  .footer-grid {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2.5rem;
    padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .wordmark { display: inline-flex; align-items: center; gap: 0.55rem; font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; color: var(--mint); }
  .wordmark sup { font-size: 0.5em; font-weight: 400; opacity: 0.7; }
  .footer-tag { margin-top: 0.9rem; max-width: 26ch; opacity: 0.6; }
  .footer-col { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-label { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.45; margin-bottom: 0.4rem; }
  .footer-base {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    padding-top: 1.75rem; font-size: 0.85rem; opacity: 0.55;
  }
  @media (max-width: 640px) { .footer-grid { grid-template-columns: 1fr; gap: 2rem; } }
</style>
