---
// §6.1 FounderStrip. Stock placeholder portraits (4:5). TODO(arya): real photos.
const founders = [
  { name: 'Arya Khaligh', img: '/images/founder-arya.jpg' },
  { name: 'Amir Gholizad', img: '/images/founder-amir.jpg' },
];
---
<div class="founders">
  <div class="founders__photos">
    {founders.map((f) => (
      <figure class="founders__fig">
        <img src={f.img} width="640" height="800" loading="lazy" decoding="async" alt={`${f.name}, co-founder of Sharplines Studio (placeholder photo).`} />
        <figcaption>{f.name}</figcaption>
      </figure>
    ))}
  </div>
  <div class="founders__copy">
    <p class="lede">Sharplines is Arya Khaligh and Amir Gholizad — senior software engineers who spent years building software in the tech industry. Now we point that experience at one problem: getting local businesses more customers. Everything we make is fast, measurable, and yours.</p>
  </div>
</div>

<style>
  .founders { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .founders__photos { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; max-width: 460px; }
  .founders__fig { margin: 0; }
  .founders__fig img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; border-radius: var(--radius); }
  .founders__fig figcaption { margin-top: 0.7rem; font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink); opacity: 0.6; }
  .founders__copy .lede { color: var(--ink); max-width: 40ch; }
  @media (min-width: 860px) { .founders { grid-template-columns: 0.85fr 1fr; } }
</style>
