---
// §6.1 FounderStrip. Real founder photos supplied by Arya. First names only.
// Circular avatars + names sit ABOVE the bio. Bulletproof circles via a fixed
// square wrapper with overflow:hidden. Copy follows the site-copy voice skill.
const founders = [
  { name: 'Arya', img: '/images/founder-arya.jpg' },
  { name: 'Amir', img: '/images/founder-amir.jpg' },
];
---
<div class="founders">
  <div class="founders__photos">
    {founders.map((f) => (
      <figure class="founders__fig">
        <span class="founders__avatar">
          <img src={f.img} width="336" height="336" loading="lazy" decoding="async" alt={`${f.name}, co-founder of Sharplines Studio.`} />
        </span>
        <figcaption>{f.name}</figcaption>
      </figure>
    ))}
  </div>
  <p class="lede founders__copy">Sharplines is Arya and Amir, two senior software engineers who spent years shipping software in tech. We now put that experience toward one problem: getting local businesses more customers. Everything we build is fast, measurable, and yours to keep.</p>
</div>

<style>
  .founders { display: flex; flex-direction: column; gap: clamp(1.75rem, 4vw, 2.75rem); align-items: flex-start; }
  .founders__photos { display: flex; gap: clamp(1.5rem, 3vw, 2.25rem); }
  .founders__fig { margin: 0; text-align: center; }
  .founders__avatar {
    display: block;
    width: clamp(120px, 20vw, 164px);
    height: clamp(120px, 20vw, 164px);
    border-radius: 50%;
    overflow: hidden;
  }
  .founders__avatar img { width: 100%; height: 100%; object-fit: cover; object-position: center 22%; display: block; }
  .founders__fig figcaption { margin-top: 0.75rem; font-size: 0.82rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink); opacity: 0.65; }
  /* Full width to match the sections above (overrides .lede's reading cap). */
  .founders__copy { color: var(--ink); max-width: none; align-self: stretch; }
</style>
