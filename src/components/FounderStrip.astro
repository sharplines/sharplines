---
// §6.1 FounderStrip. Real founder photos supplied by Arya. First names only.
// v2 (Arya, 2026-07-05: old avatar strip "looked cheap"): one ivory card in the
// pricing/services card language — rounded 4:5 portraits beside the bio.
// Copy follows the site-copy voice skill.
const founders = [
  { name: 'Arya', img: '/images/founder-arya.jpg' },
  { name: 'Amir', img: '/images/founder-amir.jpg' },
];
---
<div class="founders">
  <div class="founders__photos">
    {founders.map((f) => (
      <figure class="founders__fig">
        <img src={f.img} width="336" height="420" loading="lazy" decoding="async" alt={`${f.name}, co-founder of Sharplines Studio.`} />
        <figcaption>{f.name}</figcaption>
      </figure>
    ))}
  </div>
  <p class="founders__copy">Sharplines is Arya and Amir, two senior software engineers who spent years shipping software in tech. We now put that experience toward one problem: getting local businesses more customers. Everything we build is fast, measurable, and yours to keep.</p>
</div>

<style>
  /* Ivory card matching pricing/services v3 (14px soft radius, soft shadow). */
  .founders {
    display: grid;
    gap: clamp(1.5rem, 3.5vw, 2.5rem);
    background: var(--ivory);
    border: 1px solid rgba(14, 47, 40, 0.12);
    border-radius: 14px;
    padding: clamp(1.6rem, 4vw, 2.75rem);
    box-shadow: 0 14px 36px rgba(14, 47, 40, 0.1);
  }

  .founders__photos {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 1.5rem);
    max-width: 420px;
  }
  .founders__fig { margin: 0; }
  .founders__fig img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 22%;
    border-radius: 12px;
    display: block;
  }
  .founders__fig figcaption {
    margin-top: 0.65rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--green);
  }

  .founders__copy {
    margin: 0;
    color: var(--ink);
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.6;
    max-width: 58ch;
  }

  @media (min-width: 820px) {
    .founders { grid-template-columns: auto 1fr; align-items: center; column-gap: clamp(2.5rem, 5vw, 4rem); }
  }
</style>
