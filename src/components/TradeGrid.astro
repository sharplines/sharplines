---
import { trades } from '../data/trades';
---
<div class="tradegrid">
  {trades.map((t) => (
    <a href={`/for/${t.slug}`} class="tradetile">
      <span class="tradetile__label">{t.label}</span>
      <span class="tradetile__hook">{t.hook}</span>
      <span class="tradetile__arrow" aria-hidden="true">→</span>
    </a>
  ))}
</div>
<p class="tradegrid__foot">Don't see your trade? The same approach works for most local businesses. <a href="/contact" class="link">Get in touch</a>.</p>

<style>
  /* Mobile-first: compact two-column, name-only tiles so the section is quick to
     scan or skip on phones — Arya, 2026-07-05. Hooks return at ≥720px. */
  .tradegrid {
    display: grid; grid-template-columns: 1fr 1fr; column-gap: 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.28);
  }
  .tradetile {
    position: relative; display: flex; flex-direction: column; gap: 0.3rem;
    padding: 0.9rem 0; color: var(--ivory);
    border-bottom: 1px solid rgba(255,255,255,0.28);
    transition: padding-left 0.16s ease;
  }
  .tradetile:hover { padding-left: 0.75rem; }
  .tradetile__label { font-size: 1.1rem; font-weight: 500; line-height: 1.2; }
  .tradetile__hook { display: none; color: var(--ivory); opacity: 0.8; font-size: 0.98rem; }
  .tradetile__arrow { position: absolute; top: 1.5rem; right: 0.5rem; color: var(--ivory); opacity: 0; transition: opacity 0.16s ease, transform 0.16s ease; }
  .tradetile:hover .tradetile__arrow { opacity: 1; transform: translateX(4px); }
  .tradegrid__foot { margin-top: 1.25rem; color: var(--ivory); opacity: 0.9; }

  @media (min-width: 720px) {
    .tradegrid { column-gap: clamp(2rem, 5vw, 5rem); }
    .tradetile { padding: 1.4rem 2.5rem 1.4rem 0; }
    .tradetile__label { font-size: clamp(1.35rem, 3vw, 1.9rem); line-height: 1.1; }
    .tradetile__hook { display: block; }
    .tradegrid__foot { margin-top: 1.75rem; }
  }
</style>
