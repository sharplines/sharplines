---
// Ink CTA band with the short contact form (§6.1 CTABand).
import ContactForm from './ContactForm.astro';
interface Props {
  heading?: string;
  variant?: 'short' | 'full';
}
const {
  heading = 'See your new homepage before you spend a dollar.',
  variant = 'short',
} = Astro.props;
---
<section class="ctaband">
  <div class="container ctaband__inner fade-up">
    <div class="ctaband__copy">
      <h2>{heading}</h2>
      <p class="ctaband__mono">Prefer to talk? <a href="tel:+15145602266">(514) 560-2266</a> · <a href="mailto:hi@sharplines.ca">hi@sharplines.ca</a></p>
    </div>
    <div class="ctaband__form">
      <ContactForm variant={variant} theme="dark" />
    </div>
  </div>
</section>

<style>
  .ctaband { background: var(--ink); color: var(--paper); padding-block: clamp(3.5rem, 8vw, 6rem); }
  .ctaband__inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .ctaband h2 { color: var(--paper); max-width: 16ch; }
  .ctaband__mono {
    font-family: var(--font-mono); font-size: 0.8125rem; letter-spacing: 0.04em;
    color: var(--steel); margin-top: 1.5rem;
  }
  .ctaband__mono a { color: var(--paper); }
  @media (max-width: 820px) { .ctaband__inner { grid-template-columns: 1fr; } }
</style>
