---
import { trades } from '../data/trades';
const links = [
  { label: 'Services', href: '/services' },
  { label: 'Results', href: '/work' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="nav" data-nav>
  <div class="container nav__inner">
    <a href="/" class="wordmark" aria-label="Sharplines home">
      <span class="wordmark__sharp">Sharp</span><span>lines</span>
    </a>

    <!-- Desktop links -->
    <nav class="nav__links" aria-label="Primary">
      <a href="/services" class="nav__link">Services</a>

      <div class="nav__drop" data-drop>
        <button class="nav__link nav__dropbtn" aria-expanded="false" aria-haspopup="true" data-dropbtn>
          Who we help
          <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="nav__menu" role="menu">
          {trades.map((t) => (
            <a href={`/for/${t.slug}`} class="nav__menuitem" role="menuitem">{t.label}</a>
          ))}
        </div>
      </div>

      <a href="/work" class="nav__link">Results</a>
      <a href="/about" class="nav__link">About</a>
      <a href="/contact" class="nav__link">Contact</a>
    </nav>

    <a href="/contact?offer=preview" class="btn btn--primary nav__cta">Get my free preview</a>

    <!-- Mobile toggle -->
    <button class="nav__burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="nav__mobile" id="mobile-menu" data-mobile hidden>
    <nav aria-label="Mobile">
      {links.map((l) => <a href={l.href} class="nav__mlink">{l.label}</a>)}
      <p class="nav__mheading eyebrow">Who we help</p>
      <div class="nav__mtrades">
        {trades.map((t) => <a href={`/for/${t.slug}`} class="nav__mtrade">{t.label}</a>)}
      </div>
      <a href="/contact?offer=preview" class="btn btn--primary nav__mcta">Get my free preview</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: var(--paper);
    border-bottom: 1px solid var(--hairline);
  }
  .nav__inner { display: flex; align-items: center; gap: 1rem; height: 64px; }

  .wordmark {
    font-family: var(--font-display); font-weight: 700; font-size: 1.35rem;
    color: var(--ink); letter-spacing: -0.02em; margin-right: auto;
  }
  .wordmark__sharp { border-bottom: 2px solid var(--chalk); padding-bottom: 1px; }

  .nav__links { display: flex; align-items: center; gap: 1.75rem; margin-right: 1.5rem; }
  .nav__link {
    font-family: var(--font-body); font-weight: 500; font-size: 0.98rem;
    color: var(--ink); background: none; border: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: 0.35em; padding: 0;
  }
  .nav__link:hover { color: var(--chalk); }

  .nav__drop { position: relative; }
  .nav__menu {
    position: absolute; top: calc(100% + 0.75rem); left: 50%; transform: translateX(-50%) translateY(-6px);
    background: var(--paper); border: 1px solid var(--hairline); border-radius: var(--radius);
    padding: 0.5rem; min-width: 230px; display: grid;
    opacity: 0; visibility: hidden; transition: opacity 0.16s ease, transform 0.16s ease;
    box-shadow: 0 12px 30px rgba(23,24,28,0.08);
  }
  .nav__drop.open .nav__menu { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .nav__menuitem { padding: 0.55rem 0.75rem; border-radius: var(--radius); color: var(--ink); font-size: 0.95rem; }
  .nav__menuitem:hover { background: var(--paper); color: var(--chalk); box-shadow: inset 3px 0 0 var(--chalk); }

  .nav__cta { white-space: nowrap; }

  .nav__burger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 10px; margin-left: auto; }
  .nav__burger span { width: 24px; height: 2px; background: var(--ink); transition: transform 0.2s ease, opacity 0.2s ease; }
  .nav[data-open] .nav__burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav[data-open] .nav__burger span:nth-child(2) { opacity: 0; }
  .nav[data-open] .nav__burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav__mobile { border-top: 1px solid var(--hairline); background: var(--paper); }
  .nav__mobile nav { display: flex; flex-direction: column; padding: 1rem var(--gutter) 1.5rem; gap: 0.25rem; }
  .nav__mlink { padding: 0.85rem 0; font-size: 1.15rem; font-weight: 500; color: var(--ink); border-bottom: 1px solid var(--hairline); }
  .nav__mheading { margin: 1.25rem 0 0.5rem; }
  .nav__mtrades { display: grid; grid-template-columns: 1fr 1fr; gap: 0.25rem 1rem; }
  .nav__mtrade { padding: 0.6rem 0; font-size: 1rem; color: var(--steel); }
  .nav__mcta { margin-top: 1.25rem; width: 100%; }

  @media (max-width: 900px) {
    .nav__links, .nav__cta { display: none; }
    .nav__burger { display: flex; }
    .wordmark { margin-right: 0; }
  }
  @media (min-width: 901px) {
    .nav__mobile { display: none; }
  }
</style>

<script>
  // Desktop dropdown
  const drop = document.querySelector('[data-drop]');
  const dropBtn = document.querySelector('[data-dropbtn]');
  dropBtn?.addEventListener('click', () => {
    const open = drop?.classList.toggle('open');
    dropBtn.setAttribute('aria-expanded', String(!!open));
  });
  document.addEventListener('click', (e) => {
    if (drop && !drop.contains(e.target as Node)) { drop.classList.remove('open'); dropBtn?.setAttribute('aria-expanded', 'false'); }
  });

  // Mobile menu
  const nav = document.querySelector('[data-nav]');
  const burger = document.querySelector('[data-burger]');
  const mobile = document.querySelector('[data-mobile]') as HTMLElement | null;
  burger?.addEventListener('click', () => {
    const open = nav?.toggleAttribute('data-open');
    burger.setAttribute('aria-expanded', String(!!open));
    burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    if (mobile) mobile.hidden = !open;
  });
  mobile?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
    nav?.removeAttribute('data-open'); mobile.hidden = true; burger?.setAttribute('aria-expanded', 'false');
  }));
</script>
