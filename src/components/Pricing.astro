---
/* Home pricing block — $0-down monthly model (Arya, 2026-07-05; two plans same day).
   Copy follows .claude/skills/site-copy/SKILL.md: no em-dashes, sentence case,
   one offer per page (free preview is the only CTA). Prices in CAD. */
interface PlanRow { label: string; text?: string; list?: string[]; note?: string }
interface Plan { name: string; price: string; was: string; featured?: boolean; rows: PlanRow[] }

const plans: Plan[] = [
  {
    name: 'Growth',
    price: '$179',
    was: '$249',
    featured: true,
    rows: [
      { label: 'Upfront', text: '$0. We waive the $1,000 setup fee.' },
      { label: 'Term', text: 'Monthly. Cancel any time.' },
      { label: "What's included", list: [
        "A custom site that's yours to keep",
        'Hosting',
        'Unlimited edits through your dashboard',
        'Support when you need it',
      ] },
      { label: 'Guarantee', text: 'You see the free preview before you pay a dollar.' },
    ],
  },
  {
    name: 'Autopilot',
    price: '$649',
    was: '$949',
    rows: [
      { label: 'Upfront', text: '$0. We waive the $2,500 setup fee.' },
      { label: 'Term', text: 'Monthly. Cancel any time.' },
      { label: "What's included", list: [
        'Everything in Growth',
        'Your Google Business Profile',
        'Pages for each area you serve',
        'Review follow-ups',
        'Online booking',
        'Call tracking',
        'A monthly report',
        'Google and Meta ads, run and tracked for you',
      ], note: 'Ad spend goes straight to the platforms.' },
      { label: 'Guarantee', text: 'More leads within 90 days.' },
      { label: 'Pays for itself at', text: 'About 2 jobs a month.' },
    ],
  },
];
---

<section class="section theme-green pricing" id="pricing">
  <div class="container fade-up">
    <p class="eyebrow">Pricing</p>
    <h2 class="display-lg pricing__h">Clear pricing, nothing up front.</h2>
    <p class="lede pricing__lede">Both plans run month to month and start at $0 down. You see the free homepage preview before you pay anything, and you can start small and move up any time.</p>

    <div class="plans">
      {plans.map((plan) => (
        <article class={plan.featured ? 'plan plan--featured' : 'plan'}>
          <header class="plan__head">
            <h3 class="plan__name">{plan.name}</h3>
            {plan.featured && <span class="plan__tag">Start here</span>}
          </header>
          <p class="plan__price">
            <span class="plan__amount">{plan.price}</span>
            <span class="plan__per">a month</span>
            <span class="plan__was"><span class="vh">regular price </span><s>{plan.was}</s></span>
          </p>
          {plan.rows.map((row) => (
            <div class="plan__row">
              <span class="plan__label">{row.label}</span>
              {row.text && <p class="plan__text">{row.text}</p>}
              {row.list && (
                <ul class="plan__list">
                  {row.list.map((item) => <li>{item}</li>)}
                </ul>
              )}
              {row.note && <p class="plan__note">{row.note}</p>}
            </div>
          ))}
        </article>
      ))}
    </div>

    <div class="pricing__cta">
      <a href="/contact?offer=preview" class="btn btn--coral">Get my free homepage preview</a>
      <p class="pricing__fine">Free preview in 48 hours · No obligation · Prices in Canadian dollars</p>
    </div>
  </div>
</section>

<style>
  .pricing__h { max-width: 22ch; margin-bottom: 1.1rem; }
  .pricing__lede { opacity: 0.9; }

  .plans {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 60rem;
    margin-top: clamp(2.25rem, 5vw, 3.25rem);
  }

  .plan {
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius);
    padding: clamp(1.4rem, 3vw, 1.9rem);
  }
  .plan--featured { border: 2px solid var(--coral); }

  .plan__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-bottom: 0.95rem;
  }
  .plan__name { color: var(--ivory); font-size: 1.35rem; font-weight: 500; }
  .plan__tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: var(--coral);
    color: #fff;
    padding: 0.32rem 0.55rem;
    border-radius: var(--radius);
    white-space: nowrap;
  }

  .plan__price {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0;
    padding-block: 1rem 1.15rem;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
  }
  .plan__amount {
    font-size: clamp(2.3rem, 4.5vw, 2.9rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ivory);
  }
  .plan__per { font-size: 0.9rem; opacity: 0.75; }
  .plan__was { font-size: 1rem; opacity: 0.55; }

  .plan__row {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    padding-block: 0.85rem;
  }
  .plan__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: 0.35rem;
  }
  .plan__text { margin: 0; font-size: 0.95rem; line-height: 1.5; }

  .plan__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .plan__list li {
    position: relative;
    padding-left: 1.05rem;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .plan__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.58em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--coral);
  }
  .plan__note { margin: 0.6rem 0 0; font-size: 0.85rem; opacity: 0.7; }

  /* Two columns side by side with rows aligned across plans (subgrid). */
  @media (min-width: 760px) {
    .plans {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(7, auto);
    }
    .plan {
      display: grid;
      grid-template-rows: subgrid;
      grid-row: 1 / span 7;
      align-content: start;
    }
    .plan__head { align-items: start; }
  }

  .pricing__cta {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
  }
  .pricing__fine { margin: 0; font-size: 0.85rem; letter-spacing: 0.02em; opacity: 0.75; }
</style>
