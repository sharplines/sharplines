---
/* Home pricing block — $0-down monthly model (Arya, 2026-07-05; two plans same day).
   v3 softened look (Arya, 2026-07-05): ivory cards on the green block, rounded
   corners + soft shadow, coral checkmarks, merged upfront/term sentence, no
   uppercase row labels. Copy follows .claude/skills/site-copy/SKILL.md:
   no em-dashes, sentence case, one offer per page (free preview is the only CTA).
   Prices in CAD. */
interface Plan {
  name: string;
  tagline: string;
  price: string;
  was: string;
  featured?: boolean;
  terms: string;
  includes: string[];
  footer: string;
}

const plans: Plan[] = [
  {
    name: 'Growth',
    tagline: 'Your new website, live and looked after.',
    price: '$179',
    was: '$249',
    featured: true,
    terms: '$0 down. We waive the $1,000 setup fee. Cancel any time.',
    includes: [
      "A custom site that's yours to keep",
      'Hosting',
      'Unlimited edits through your dashboard',
      'Support when you need it',
    ],
    footer: 'You see the free preview before you pay a dollar.',
  },
  {
    name: 'Autopilot',
    tagline: 'Everything online, handled for you.',
    price: '$495',
    was: '$849',
    terms: '$0 down. We waive the $2,500 setup fee. Cancel any time.',
    includes: [
      'Everything in Growth',
      'Your Google Business Profile',
      'Pages for each area you serve',
      'Review follow-ups',
      'Online booking',
      'Call tracking',
      'A monthly report',
      'Google and Meta ads, run and tracked for you',
    ],
    footer: 'We guarantee more leads within 90 days. It pays for itself at about 2 jobs a month.',
  },
];
---

<section class="section theme-green pricing" id="pricing">
  <div class="container fade-up">
    <p class="eyebrow">Pricing</p>
    <h2 class="display-lg pricing__h">Clear pricing, nothing up front.</h2>
    <p class="lede pricing__lede">Both plans run month to month and start at $0 down. You see the free homepage preview before you pay anything, and you can start small and move up any time.</p>

    <div class="plans">
      {plans.map((plan) => (
        <article class={plan.featured ? 'plan plan--featured' : 'plan'}>
          <header class="plan__head">
            <div class="plan__title">
              <h3 class="plan__name">{plan.name}</h3>
              {plan.featured && <span class="plan__tag">Start here</span>}
            </div>
            <p class="plan__tagline">{plan.tagline}</p>
          </header>
          <p class="plan__price">
            <span class="plan__amount">{plan.price}</span>
            <span class="plan__per">a month</span>
            <span class="plan__was"><span class="vh">regular price </span><s>{plan.was}</s></span>
          </p>
          <p class="plan__terms">{plan.terms}</p>
          <div class="plan__includes">
            <p class="plan__inc-label">What's included</p>
            <ul class="plan__list">
              {plan.includes.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <p class="plan__foot">{plan.footer}</p>
        </article>
      ))}
    </div>

    <div class="pricing__cta">
      <a href="/contact?offer=preview" class="btn btn--coral">Get my free homepage preview</a>
      <p class="pricing__fine">Free preview in 48 hours · No obligation · Prices in Canadian dollars</p>
    </div>
  </div>
</section>

<style>
  .pricing__h { max-width: 22ch; margin-bottom: 1.1rem; }
  .pricing__lede { opacity: 0.9; }

  .plans {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: clamp(2.25rem, 5vw, 3.25rem);
  }

  /* Warm ivory cards on the green block. Corners intentionally rounder than the
     3px token (buttons/inputs keep 3px) to soften the section — Arya, 2026-07-05. */
  .plan {
    background: var(--ivory);
    color: var(--ink);
    border-radius: 14px;
    padding: clamp(1.6rem, 3.5vw, 2.4rem);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
  }
  .plan--featured { border: 2px solid var(--coral); }

  .plan__head { padding-bottom: 1.1rem; }
  .plan__title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .plan__name { color: var(--green); font-size: 1.45rem; font-weight: 500; }
  .plan__tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: var(--coral);
    color: #fff;
    padding: 0.32rem 0.6rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .plan__tagline { margin: 0.45rem 0 0; font-size: 0.95rem; opacity: 0.75; }

  .plan__price {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0;
    padding-bottom: 0.55rem;
  }
  .plan__amount {
    font-size: clamp(2.4rem, 4.5vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--green);
  }
  .plan__per { font-size: 0.9rem; opacity: 0.7; }
  .plan__was { font-size: 1rem; opacity: 0.5; }

  .plan__terms {
    margin: 0;
    padding-bottom: 1.15rem;
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.85;
  }

  .plan__includes {
    border-top: 1px solid rgba(14, 47, 40, 0.14);
    padding-block: 1.15rem;
  }
  .plan__inc-label {
    margin: 0 0 0.8rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--green);
  }
  .plan__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .plan__list li {
    position: relative;
    padding-left: 1.55rem;
    font-size: 0.96rem;
    line-height: 1.5;
  }
  .plan__list li::before {
    content: "";
    position: absolute;
    left: 0.15rem;
    top: 0.42em;
    width: 0.6rem;
    height: 0.32rem;
    border-left: 2px solid var(--coral);
    border-bottom: 2px solid var(--coral);
    transform: rotate(-45deg);
  }

  .plan__foot {
    margin: 0;
    border-top: 1px solid rgba(14, 47, 40, 0.14);
    padding-top: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
    opacity: 0.7;
    align-self: end;
  }

  /* Two columns side by side with rows aligned across plans (subgrid). */
  @media (min-width: 760px) {
    .plans {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(5, auto);
    }
    .plan {
      display: grid;
      grid-template-rows: subgrid;
      grid-row: 1 / span 5;
      align-content: start;
    }
  }

  .pricing__cta {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
  }
  .pricing__fine { margin: 0; font-size: 0.85rem; letter-spacing: 0.02em; opacity: 0.75; }
</style>
