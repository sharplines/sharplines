---
// Home hero (§6.1). The chalk line snaps under "booked jobs".
---
<section class="hero">
  <div class="container hero__inner">
    <p class="eyebrow">Toronto &amp; GTA — local business growth</p>
    <h1 class="hero__h1">We turn local searches into <span class="chalk-underline">booked jobs</span>.</h1>
    <p class="hero__sub">Sharplines builds the website, reviews, and follow-up systems that make GTA businesses the obvious choice — then keeps the calls coming.</p>
    <div class="hero__cta">
      <a href="/contact?offer=preview" class="btn btn--primary">See my new homepage — free</a>
      <a href="/contact" class="btn btn--secondary">Book a 15-min call</a>
    </div>
    <p class="hero__note">Free preview in 48 hours · No obligation</p>
  </div>
</section>

<style>
  .hero { padding-block: clamp(3.5rem, 9vw, 7rem) clamp(3rem, 7vw, 5rem); }
  .hero__inner { max-width: 22ch; }
  .hero__h1 { max-width: 15ch; margin-bottom: 1.5rem; }
  .hero__sub { font-size: clamp(1.1rem, 1.6vw, 1.3rem); color: var(--steel); max-width: 46ch; margin-bottom: 2rem; }
  .hero__inner { max-width: none; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.85rem; }
  .hero__note { font-family: var(--font-mono); font-size: 0.8125rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--steel); margin-top: 1.5rem; }

  @media (max-width: 560px) {
    .hero__cta { flex-direction: column; align-items: stretch; }
    .hero__cta .btn { width: 100%; }
  }
</style>
