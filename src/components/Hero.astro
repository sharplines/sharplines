---
// Full-bleed photo hero. Copy is spec §6.1 verbatim.
---
<section class="hero">
  <div class="hero__bg">
    <img src="/images/hero.jpg" alt="" aria-hidden="true" width="2000" height="1125" fetchpriority="high" />
    <span class="hero__scrim"></span>
  </div>

  <div class="container hero__content">
    <p class="eyebrow hero__eyebrow">Toronto &amp; GTA — local business growth</p>
    <h1 class="hero__h1">We turn local searches into <span class="line-accent">booked jobs</span>.</h1>
    <p class="hero__sub">Sharplines builds the website, reviews, and follow-up systems that make GTA businesses the obvious choice — then keeps the calls coming.</p>
    <div class="hero__cta">
      <a href="/contact?offer=preview" class="btn btn--coral">See my new homepage — free</a>
      <a href="/contact" class="btn btn--outline-light">Book a 15-min call</a>
    </div>
    <p class="hero__note">Free preview in 48 hours · No obligation</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    color: var(--ivory);
    overflow: hidden;
  }
  .hero__bg { position: absolute; inset: 0; z-index: 0; }
  .hero__bg img { width: 100%; height: 100%; object-fit: cover; object-position: 65% center; }
  .hero__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(14,47,40,0.55) 0%, rgba(14,47,40,0.15) 38%, rgba(10,26,22,0.82) 100%),
      linear-gradient(90deg, rgba(10,26,22,0.55) 0%, rgba(10,26,22,0) 55%);
  }
  .hero__content { position: relative; z-index: 1; padding-block: 7.5rem clamp(3rem, 8vh, 6rem); }
  .hero__eyebrow { color: var(--ivory); opacity: 0.9; }
  .hero__h1 { color: var(--ivory); font-size: var(--t-hero); max-width: 16ch; }
  .hero__sub { color: var(--ivory); font-size: clamp(1.08rem, 1.6vw, 1.35rem); max-width: 42ch; margin: 1.5rem 0 2rem; opacity: 0.94; }
  .hero__cta { display: flex; flex-direction: column; gap: 0.75rem; }
  .hero__note { font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.85; margin-top: 1.5rem; }

  @media (min-width: 640px) {
    .hero__cta { flex-direction: row; flex-wrap: wrap; }
  }
</style>
