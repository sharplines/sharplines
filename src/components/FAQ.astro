---
interface Props { items: { q: string; a: string }[]; }
const { items } = Astro.props;
---
<div class="faq">
  {items.map((item) => (
    <details class="faq__item">
      <summary class="faq__q">
        <span>{item.q}</span>
        <svg class="faq__icon" width="18" height="18" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
      </summary>
      <div class="faq__a"><p>{item.a}</p></div>
    </details>
  ))}
</div>

<style>
  .faq { border-top: 1px solid rgba(14,47,40,0.16); }
  .faq__item { border-bottom: 1px solid rgba(14,47,40,0.16); }
  .faq__q {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.35rem 0; cursor: pointer; list-style: none;
    font-size: clamp(1.1rem, 2vw, 1.35rem); font-weight: 500; color: var(--green);
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__icon { flex: none; color: var(--coral); transition: transform 0.2s ease; }
  .faq__item[open] .faq__icon { transform: rotate(45deg); }
  .faq__a { padding: 0 0 1.5rem; max-width: 64ch; }
  .faq__a p { color: var(--ink); opacity: 0.82; margin: 0; }
</style>
