---
interface Props { items?: string[]; }
const {
  items = [
    '2× more clients — Provolta Electric, Toronto',
    'Built by senior software engineers',
    'Websites, reviews, booking & ads — one team',
  ],
} = Astro.props;
---
<section class="proofbar theme-green">
  <div class="container proofbar__inner">
    {items.map((item) => <p class="proofbar__item">{item}</p>)}
  </div>
</section>

<style>
  .proofbar { padding-block: clamp(1.75rem, 4vw, 2.5rem); }
  .proofbar__inner { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .proofbar__item {
    margin: 0; padding: 0.9rem 0;
    font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ivory); opacity: 0.92;
    border-top: 1px solid rgba(255,255,255,0.16);
  }
  .proofbar__item:first-child { border-top: none; }
  @media (min-width: 760px) {
    .proofbar__inner { grid-template-columns: repeat(3, 1fr); gap: 0; }
    .proofbar__item { border-top: none; padding: 0 1.75rem; }
    .proofbar__item:first-child { padding-left: 0; }
    .proofbar__item + .proofbar__item { border-left: 1px solid rgba(255,255,255,0.16); }
  }
</style>
