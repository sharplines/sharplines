---
import Base from '../layouts/Base.astro';
---
<Base title="Thank you — Sharplines Studio">
  <section class="ty theme-green">
    <div class="container ty__inner">
      <p class="eyebrow">Free homepage preview</p>
      <h1 class="display-xl">Got it. Talk soon.</h1>
      <p class="ty__sub">We've received your details — you'll hear from us the same business day, and your homepage preview lands within 48 hours.</p>
      <a href="/" class="btn btn--ivory">← Back home</a>
    </div>
  </section>
</Base>

<style>
  .ty { min-height: 82vh; display: flex; align-items: center; }
  .ty__inner { padding-block: 8rem; }
  .ty .eyebrow { color: var(--coral); }
  .ty h1 { color: var(--ivory); }
  .ty__sub { color: var(--ivory); opacity: 0.9; font-size: 1.2rem; max-width: 44ch; margin: 1.25rem 0 2rem; }
</style>
