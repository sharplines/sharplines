---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Thank you — SharpLines">
  <Header />
  <main class="ty theme-green">
    <div class="container ty-inner">
      <h1 class="display-xl">Thank you.</h1>
      <p>We've received your message and will be in touch shortly.</p>
      <a href="/" class="btn btn--light">← Back home</a>
    </div>
  </main>
  <Footer />

  <style>
    .ty { min-height: 80vh; display: flex; align-items: center; color: var(--ivory); }
    .ty-inner { padding-block: 8rem; }
    .ty h1 { color: var(--ivory); }
    .ty p { margin: 1.25rem 0 2rem; font-size: 1.2rem; }
  </style>
</Base>
