---
// Contact (§6.5): one green block, one purpose — the free preview. Full form in
// an ivory card (v3 card language). On mobile the form follows the heading
// directly; the what-happens-next steps and direct contact sit beside it on
// desktop. ?offer=preview preselect is handled inside ContactForm.
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';

const steps = [
  'Send the form. It takes about a minute.',
  'We get in touch the same business day.',
  "Your free homepage preview is ready within 48 hours. If you don't love it, you've lost nothing.",
];
---

<Base
  title="Start with a free preview | Sharplines Studio"
  description="Tell us a bit about your business. You'll hear from us the same business day, and your free homepage preview will be ready within 48 hours. No obligation."
  navSolid
>
  <section class="contact theme-green">
    <div class="container contact__grid">
      <header class="contact__head">
        <p class="eyebrow">Free homepage preview</p>
        <h1 class="display-xl contact__h">Start with a <span class="line-accent">free preview</span>.</h1>
        <p class="contact__sub">Fill this in and you'll hear from us the same business day. Your homepage preview will be ready within 48 hours.</p>
        <p class="contact__fine">Free · No obligation · No contract</p>
      </header>

      <div class="contact__card">
        <ContactForm variant="full" theme="light" />
      </div>

      <aside class="contact__aside">
        <p class="eyebrow">What happens next</p>
        <ol class="contact__steps">
          {steps.map((s, i) => (
            <li>
              <span class="contact__n">0{i + 1}</span>
              <p>{s}</p>
            </li>
          ))}
        </ol>
        <div class="contact__direct">
          <div class="contact__people">
            <img src="/images/founder-arya.jpg" alt="Arya, co-founder of Sharplines Studio." width="112" height="140" loading="lazy" decoding="async" />
            <img src="/images/founder-amir.jpg" alt="Amir, co-founder of Sharplines Studio." width="112" height="140" loading="lazy" decoding="async" />
            <p>You'll hear directly from Arya or Amir.</p>
          </div>
          <p>Prefer to talk it through? Call <a href="tel:+15145602266" class="link">(514) 560-2266</a>.</p>
          <p>Or write to <a href="mailto:hi@sharplines.ca" class="link">hi@sharplines.ca</a> and tell us what you're after.</p>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  /* Fixed transparent nav sits over the green block; pad past its 76px height. */
  .contact { padding-block: calc(76px + clamp(2.5rem, 6vw, 4.5rem)) clamp(3.5rem, 7vw, 5.5rem); }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas: 'head' 'card' 'aside';
    gap: clamp(2rem, 5vw, 3rem);
    align-items: start;
  }
  .contact__head { grid-area: head; }
  .contact__card { grid-area: card; }
  .contact__aside { grid-area: aside; }

  .contact__h { color: var(--ivory); max-width: 14ch; }
  .contact__sub { margin: 1.25rem 0 0; color: var(--mint); opacity: 0.92; font-size: clamp(1.05rem, 1.6vw, 1.25rem); max-width: 46ch; }
  .contact__fine { margin: 1rem 0 0; font-size: 0.85rem; letter-spacing: 0.02em; color: var(--mint); opacity: 0.75; }

  /* Ivory form card, matching the pricing plan cards. */
  .contact__card {
    background: var(--ivory);
    border-radius: 14px;
    padding: clamp(1.6rem, 4vw, 2.5rem);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
  }

  .contact__steps { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.1rem; }
  .contact__steps li {
    display: grid; grid-template-columns: auto 1fr; gap: 0.9rem; align-items: baseline;
    border-top: 1px solid rgba(255, 255, 255, 0.18); padding-top: 1rem;
  }
  .contact__n { font-size: 0.85rem; letter-spacing: 0.16em; font-weight: 600; color: var(--coral); }
  .contact__steps p { margin: 0; color: var(--ivory); opacity: 0.9; }

  .contact__direct { margin-top: 2rem; color: var(--mint); }
  .contact__direct p { opacity: 0.85; }

  /* The real founders, small: same 4:5 crop as the home founders card. */
  .contact__people { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1.4rem; }
  .contact__people img {
    width: 56px;
    aspect-ratio: 4 / 5;
    height: auto;
    object-fit: cover;
    object-position: center 22%;
    border-radius: 10px;
  }
  .contact__people p { margin: 0 0 0 0.5rem; color: var(--ivory); opacity: 0.92; }

  @media (min-width: 900px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-areas: 'head card' 'aside card';
      gap: clamp(2.5rem, 5vw, 4rem);
      column-gap: clamp(3rem, 6vw, 5rem);
    }
  }
</style>
