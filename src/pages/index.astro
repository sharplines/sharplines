---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ProofBar from '../components/ProofBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CaseStudyFeature from '../components/CaseStudyFeature.astro';
import StepTimeline from '../components/StepTimeline.astro';
import TradeGrid from '../components/TradeGrid.astro';
import FounderStrip from '../components/FounderStrip.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';

const servicesList = [
  { title: 'Websites that sell', blurb: 'A fast, clean site built to turn visitors into calls and quotes. Rebuilt from scratch, live in weeks.', href: '/services#websites' },
  { title: 'Get found on Google', blurb: 'Local SEO and your Google Business Profile, tuned so you show up when your neighbourhood searches for what you do.', href: '/services#seo' },
  { title: 'Reviews on autopilot', blurb: 'Every finished job triggers a friendly follow-up asking for a Google review. Your rating climbs while you work.', href: '/services#reviews' },
  { title: 'Online booking', blurb: 'Customers book you in two taps. Reminders cut no-shows.', href: '/services#booking' },
  { title: 'Never miss a call', blurb: 'After hours, your phone gets answered, the details get taken, and you get a text with who called and why.', href: '/services#phone' },
  { title: 'Social on autopilot', blurb: 'Your best work, posted to Instagram and TikTok on schedule. You send photos; we handle the rest.', href: '/services#social' },
  { title: 'Ads that pay for themselves', blurb: 'Google Ads aimed at people ready to hire, tracked to the call — so you know what every dollar brought back.', href: '/services#ads' },
];

const faqs = [
  { q: 'How much does it cost?', a: "Our pricing is competitive with GTA agencies, and every plan is scoped to what your business actually needs. The preview is free either way — book a call and we'll give you a straight number." },
  { q: "What's the catch with the free homepage preview?", a: "There isn't one. We design a homepage concept for your business in 48 hours. If you don't love it, you've lost nothing." },
  { q: 'How fast will I see results?', a: "The site and booking improvements show up immediately. Reviews build within weeks. Google rankings typically move in 2–4 months — we'll show you the progress either way." },
  { q: 'I already have a website.', a: "Most of our clients did. If it isn't bringing you calls, it's a brochure, not a salesperson. The preview will show you the difference side by side." },
  { q: 'Am I locked into a contract?', a: 'No long-term lock-in. We keep clients by performing, month after month.' },
];
---

<Base>
  <Hero />
  <ProofBar />

  <!-- Services grid -->
  <section class="section rail" id="services">
    <div class="container rail__tick fade-up">
      <p class="eyebrow">What you get</p>
      <h2 class="sec-h">Everything a local business needs to win online.</h2>
      <div class="sgrid">
        {servicesList.map((s) => <ServiceCard title={s.title} blurb={s.blurb} href={s.href} />)}
      </div>

      <a href="/services#dashboard" class="dashboard">
        <div>
          <p class="eyebrow">The Sharplines dashboard</p>
          <p class="dashboard__body">Log in any time, type what you want changed — "add a photo of yesterday's panel job", "post about our spring special" — and it's live in minutes. Your website, finally under your control.</p>
        </div>
        <span class="dashboard__more">See how it works →</span>
      </a>
    </div>
  </section>

  <!-- Case study -->
  <section class="section rail">
    <div class="container rail__tick fade-up">
      <p class="eyebrow">Results</p>
      <CaseStudyFeature />
    </div>
  </section>

  <!-- How it works -->
  <section class="section rail">
    <div class="container rail__tick fade-up">
      <p class="eyebrow">How it works</p>
      <h2 class="sec-h">Three steps, no risk.</h2>
      <StepTimeline />
    </div>
  </section>

  <!-- Trades -->
  <section class="section rail">
    <div class="container rail__tick fade-up">
      <p class="eyebrow">Who we help</p>
      <h2 class="sec-h">Built for the businesses that keep the GTA running.</h2>
      <TradeGrid />
    </div>
  </section>

  <!-- Founders -->
  <section class="section rail">
    <div class="container rail__tick fade-up">
      <p class="eyebrow">Who's behind it</p>
      <h2 class="sec-h">Two engineers, obsessed with your phone ringing.</h2>
      <FounderStrip />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section rail">
    <div class="container rail__tick fade-up faq-wrap">
      <p class="eyebrow">Questions</p>
      <h2 class="sec-h">Good questions, straight answers.</h2>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTABand />
</Base>

<style>
  .sec-h { max-width: 20ch; margin-bottom: clamp(2rem, 5vw, 3rem); }

  .sgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  @media (max-width: 900px) { .sgrid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .sgrid { grid-template-columns: 1fr; } }

  .dashboard {
    display: flex; align-items: center; justify-content: space-between; gap: 2rem;
    margin-top: 1rem; padding: 2rem;
    border: 1px solid var(--hairline); border-radius: var(--radius);
    background: var(--ink); color: var(--paper);
  }
  .dashboard .eyebrow { color: var(--chalk); }
  .dashboard__body { color: var(--paper); font-size: 1.1rem; margin: 0; max-width: 62ch; }
  .dashboard__more { flex: none; font-family: var(--font-mono); font-size: 0.8125rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--paper); white-space: nowrap; }
  .dashboard:hover { box-shadow: inset 4px 0 0 var(--chalk); }
  @media (max-width: 700px) { .dashboard { flex-direction: column; align-items: flex-start; gap: 1.25rem; } }

  .faq-wrap { max-width: 820px; }
</style>
