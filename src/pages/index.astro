---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ProofBar from '../components/ProofBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CaseStudyFeature from '../components/CaseStudyFeature.astro';
import StepTimeline from '../components/StepTimeline.astro';
import TradeGrid from '../components/TradeGrid.astro';
import FounderStrip from '../components/FounderStrip.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';

const servicesList = [
  { title: 'Websites that sell', blurb: 'A fast, clean site built to turn visitors into calls and quotes. We rebuild it from scratch and take it live in weeks.', href: '/services#websites' },
  { title: 'Get found on Google', blurb: 'Local SEO and your Google Business Profile, tuned so you show up when your neighbourhood searches for what you do.', href: '/services#seo' },
  { title: 'Reviews that keep coming', blurb: 'Every finished job triggers a friendly follow-up asking for a Google review. Your rating climbs while you work.', href: '/services#reviews' },
  { title: 'Online booking', blurb: 'Customers book you in two taps. Reminders cut no-shows.', href: '/services#booking' },
  { title: 'Never miss a call', blurb: 'After hours, your phone gets answered, the details get taken, and you get a text with who called and why.', href: '/services#phone' },
  { title: 'Ads that pay for themselves', blurb: 'Google Ads aimed at people ready to hire, tracked to the call, so you know what every dollar brought back.', href: '/services#ads' },
];

const faqs = [
  { q: 'How much does it cost?', a: "Our pricing is competitive with GTA agencies, and every plan is scoped to what your business actually needs. The preview is free either way. Book a call and we'll give you a straight number." },
  { q: "What's the catch with the free homepage preview?", a: "There isn't one. We design a homepage concept for your business in 48 hours. If you don't love it, you've lost nothing." },
  { q: 'How fast will I see results?', a: "The site and booking improvements show up right away. Reviews build within weeks. Google rankings usually take two to four months, and we'll show you the progress along the way." },
  { q: 'I already have a website.', a: "Most of our clients did. If your site isn't bringing you calls, it isn't doing its job. The free preview shows you the difference side by side." },
  { q: 'Am I locked into a contract?', a: "No. There's no long-term contract. We keep clients by getting results, month after month." },
];
---

<Base>
  <Hero />

  <!-- Who we help (coral signature block) — sits directly under the hero -->
  <section class="section theme-coral who">
    <div class="container fade-up">
      <p class="eyebrow">Who we help</p>
      <h2 class="display-xxl who__h">Built for the businesses that keep the GTA running.</h2>
      <TradeGrid />
    </div>
  </section>

  <ProofBar />

  <!-- Services grid (light) -->
  <section class="section" id="services">
    <div class="container fade-up">
      <p class="eyebrow">What you get</p>
      <h2 class="display-lg sec-h">Everything a local business needs to win online.</h2>
      <div class="sgrid">
        {servicesList.map((s) => <ServiceCard title={s.title} blurb={s.blurb} href={s.href} />)}
      </div>

      <a href="/services#dashboard" class="dashboard theme-coral">
        <div>
          <p class="eyebrow">The Sharplines dashboard</p>
          <p class="dashboard__body">Log in any time and type what you want changed, like "add a photo of yesterday's panel job" or "post about our spring special". It's live in minutes. No tickets, no waiting on an agency.</p>
        </div>
        <span class="dashboard__more">See how it works →</span>
      </a>
    </div>
  </section>

  <!-- Results (light) -->
  <section class="section">
    <div class="container fade-up">
      <p class="eyebrow">Results</p>
      <CaseStudyFeature />
    </div>
  </section>

  <!-- How it works (dark green block) -->
  <section class="section theme-green">
    <div class="container fade-up">
      <p class="eyebrow">How it works</p>
      <h2 class="display-lg sec-h">Three steps, no risk.</h2>
      <StepTimeline />
    </div>
  </section>

  <!-- Founders (light) -->
  <section class="section">
    <div class="container fade-up">
      <p class="eyebrow">Who's behind it</p>
      <h2 class="display-lg sec-h">Meet the two engineers behind Sharplines.</h2>
      <FounderStrip />
    </div>
  </section>

  <!-- FAQ (light) -->
  <section class="section">
    <div class="container fade-up">
      <p class="eyebrow">Questions</p>
      <h2 class="display-lg sec-h">Answers to the questions we hear most.</h2>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTABand />
</Base>

<style>
  .sec-h { max-width: 20ch; margin-bottom: clamp(2rem, 5vw, 3.25rem); }

  .sgrid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 620px) { .sgrid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1000px) { .sgrid { grid-template-columns: repeat(3, 1fr); } }

  .dashboard {
    display: flex; flex-direction: column; align-items: flex-start; gap: 1.5rem;
    margin-top: 1.25rem; padding: clamp(1.75rem, 4vw, 2.75rem);
    border-radius: var(--radius); color: var(--ivory);
  }
  .dashboard .eyebrow { color: var(--ivory); opacity: 0.9; }
  .dashboard__body { color: var(--ivory); font-size: clamp(1.1rem, 1.8vw, 1.35rem); margin: 0; max-width: 60ch; }
  .dashboard__more { font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ivory); font-weight: 600; white-space: nowrap; }
  .dashboard:hover .dashboard__more { text-decoration: underline; text-underline-offset: 4px; }
  @media (min-width: 820px) {
    .dashboard { flex-direction: row; align-items: center; justify-content: space-between; gap: 2.5rem; }
  }

  .who__h { max-width: 18ch; margin-bottom: clamp(2.5rem, 6vw, 4.5rem); }
</style>
