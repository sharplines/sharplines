---
// One typeface everywhere (§3.3) — Figtree variable stands in for the
// reference's licensed Halyard Display.
import '@fontsource-variable/figtree';
import '../styles/global.css';

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Websites & Marketing for Local GTA Businesses | Sharplines Studio',
  description = 'Sharplines builds websites, local SEO, reviews, booking and ad systems that get Toronto & GTA businesses more booked jobs. See your new homepage free in 48 hours.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://sharplines.ca').href;

// Sitewide ProfessionalService schema (§9) — no address.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Sharplines Studio',
  url: 'https://sharplines.ca',
  email: 'hi@sharplines.ca',
  telephone: '+15145602266',
  areaServed: 'Toronto & Greater Toronto Area',
  description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#0E2F28" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Enable JS-only enhancements (fade-up) before paint; no flash. -->
    <script is:inline>document.documentElement.classList.add('js');</script>

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a href="#main" class="vh">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <MobileCTA />

    <!-- Fade-up on section entry (§3.4) -->
    <script>
      const els = document.querySelectorAll('.fade-up');
      const showAll = () => els.forEach((el) => el.classList.add('in'));
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
        // Safety: never let a section stay hidden if the observer misses it.
        window.addEventListener('load', () => setTimeout(showAll, 1500));
      } else {
        showAll();
      }
    </script>
  </body>
</html>
